<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tracker.controllers.PomodoroController"
      styleClass="page">

    <HBox styleClass="topbar" alignment="CENTER_LEFT">
        <Label text="Pomodoro Timer" styleClass="page-title"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll">
        <VBox styleClass="page-body" spacing="16">

            <VBox styleClass="card,pom-card" alignment="CENTER" spacing="14">
                <Label fx:id="modeLabel"    styleClass="pom-mode"/>
                <Label fx:id="timerLabel"   styleClass="pom-timer" text="25:00"/>
                <HBox fx:id="dotsContainer" spacing="10" alignment="CENTER"/>
                <Label fx:id="sessionLabel" styleClass="pom-session"/>

                <HBox spacing="10" alignment="CENTER">
                    <VBox spacing="4">
                        <Label text="Work (min)" styleClass="metric-label"/>
                        <TextField fx:id="workInput" prefWidth="70" promptText="25" styleClass="input"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Break (min)" styleClass="metric-label"/>
                        <TextField fx:id="breakInput" prefWidth="70" promptText="5" styleClass="input"/>
                    </VBox>
                </HBox>
                <Button text="Update Intervals" onAction="#onChangeTime" styleClass="btn-secondary"/>

                <HBox spacing="16" alignment="CENTER">
                    <Button fx:id="startPauseBtn" text="Start"
                            onAction="#onStartPause" styleClass="btn-primary,btn-large"/>
                    <Button text="Reset"
                            onAction="#onReset"     styleClass="btn-secondary,btn-large"/>
                </HBox>
            </VBox>

            <VBox styleClass="card" spacing="8">
                <Label text="Focus sessions — last 7 days" styleClass="card-title"/>
                <BarChart fx:id="weekChart" prefHeight="200" animated="false">
                    <xAxis><CategoryAxis/></xAxis>
                    <yAxis><NumberAxis lowerBound="0"/></yAxis>
                </BarChart>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>